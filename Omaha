import pandas as pd
import re
from thefuzz import fuzz

# Load data
df = pd.read_excel("/content/drive/MyDrive/mapped_results25.xlsx")

# 1. Convert Omaha_Classification to problem_sign/symptom format
def convert_omaha_to_pair(text):
    """Convert LLM output to standardized problem_symptom format"""
    if pd.notna(text):
        problem = re.search(r"Problem:\s*(.*?)(?=\n|$)", text, re.IGNORECASE)
        symptom = re.search(r"Signs/Symptoms:\s*(.*?)(?=\n|$)", text, re.IGNORECASE)

        if problem and symptom:
            # Clean and standardize formatting
            p = problem.group(1).strip().replace("_", " ").lower()
            s = symptom.group(1).strip().replace("_", " ").lower()
            return f"{p}_{s}"
    return None

# Create standardized pairs for LLM
df['LLM_Pair'] = df['Omaha_Classification'].apply(convert_omaha_to_pair)

# 2. Get all unique human pairs from OS_SS_1 and OS_SS_2 columns
# Get all human pairs as a list (not a set)
human_pairs = set()
for col in ['OS_SS_1', 'OS_SS_2']:
    human_pairs.update(
        [x.lower().strip().replace(" ", "_") for x in df[col].dropna() if "_" in x]
    )


# Get unique LLM pairs
llm_pairs = set(df['LLM_Pair'].dropna())

# 3. Split unique pairs into components (problems and symptoms)
def split_components(pairs):
    problems, symptoms = [], []
    for pair in pairs:
        if "_" in pair:
            p, s = pair.split("_", 1)
            problems.append(p)
            symptoms.append(s)
    return problems, symptoms

# Split unique LLM and human pairs into problems and symptoms
llm_problems, llm_symptoms = split_components(llm_pairs)
human_problems, human_symptoms = split_components(human_pairs)

# 4. Matching function
def match_components(predicted, reference, threshold=80):
    matches = 0
    matched_reference = []  # Track matched reference items (allow duplicates)
    reference_list = list(reference)  # Convert set to list for counting duplicates
    for p in predicted:
        for r in reference_list:
            if fuzz.ratio(p, r) >= threshold and matched_reference.count(r) < reference_list.count(r):
                matches += 1
                matched_reference.append(r)  # Track this match (including duplicates)
                break
    return matches



# 5. Metric calculation function
def calculate_metrics(matches, predicted_count, reference_count):
    precision = matches / predicted_count if predicted_count > 0 else 0
    recall = matches / reference_count if reference_count > 0 else 0
    f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0
    return precision, recall, f1


