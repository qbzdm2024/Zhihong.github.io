def extract_omaha_info(text):
    problem, symptoms = "None", "None"
    if pd.notna(text):
        text = re.sub(r"-\s*", "", text)  # Remove leading dashes
        text = text.replace("**Problem:**", "Problem: ").replace("**Signs/Symptoms:**", "Signs/Symptoms: ")
        parts = text.split("\n")
        for part in parts:
            if "Problem:" in part:
                problem = part.replace("Problem:", "").strip()
            if "Signs/Symptoms:" in part:
                symptoms = part.replace("Signs/Symptoms:", "").strip()
    return problem, symptoms

# Function to split human-identified problem and sign/symptom
def split_human_info(text):
    if pd.isna(text) or text.strip() == "":
        return None, None
    parts = text.split("_")
    if len(parts) == 2:
        return parts[0].strip(), parts[1].strip()
    return text.strip(), None

# Function to compute fuzzy matching, ensuring 'None' values match each other
def fuzzy_match(pred, true, threshold=80):
    if (pred == "None" and true == "None") or (pd.isna(pred) and pd.isna(true)):
        return True
    if pd.isna(pred) or pd.isna(true) or pred.strip() == "" or true.strip() == "":
        return False
    return fuzz.ratio(str(pred).lower(), str(true).lower()) >= threshold

# Function to compute precision, recall, and F1 score
def compute_metrics(matches, total_pred, total_true):
    tp = matches
    fn = total_true - matches
    fp = total_pred - matches

    precision = tp / (tp + fp) if (tp + fp) > 0 else 0
    recall = tp / (tp + fn) if (tp + fn) > 0 else 0
    f1_score = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0

    return precision, recall, f1_score

