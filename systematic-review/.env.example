# ── OpenAI Configuration ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: override for Azure/proxy

# ── Model Assignments (task-specific) ────────────────────────────────────
# Agent 1 models
MODEL_TITLE_SCREENING=gpt-4o-mini          # fast & cheap for initial T/A screening
MODEL_FULLTEXT_SCREENING=gpt-4o            # stronger model for full-text decisions
MODEL_EXTRACTION=gpt-4o                    # best model for structured extraction
MODEL_QA_ASSESSMENT=gpt-4o                 # quality assessment
MODEL_SYNTHESIS=gpt-4o                     # evidence synthesis

# Agent 2 models (independent verification)
MODEL_AGENT2_SCREENING=gpt-4o              # different from agent1 for true independence
MODEL_AGENT2_EXTRACTION=gpt-4o-mini        # can use cheaper model as second extractor

# ── Decision Thresholds ───────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.80   # min confidence for auto-approval (0.5–1.0)
AGREEMENT_REQUIRED=true      # require both agents to agree before auto-approving

# ── Data Paths ────────────────────────────────────────────────────────────
DATA_DIR=data
RAW_DIR=data/raw              # place search export files here (RIS, CSV, BibTeX, etc.)
DEDUPED_DIR=data/deduped
SCREENED_DIR=data/screened
EXTRACTED_DIR=data/extracted
OUTPUT_DIR=data/output
PDF_DIR=data/pdfs             # place or upload PDF files here (named by record_id.pdf)
